# ----------------------------------------
# docker-compose variable substitution
# ----------------------------------------

# GitHub Container Registry namespace (user or org name).
# Example: GHCR_NAMESPACE=mygithubuser
GHCR_NAMESPACE=xiya233

# App image tag used by frontend/backend services.
# Common values: latest, sha-xxxxxxx, v1.2.3
APP_IMAGE_TAG=latest

# Runtime UID used by frontend/backend container processes via gosu.
# Set to host user ID to avoid bind-mount permission issues.
PUID=1000

# Runtime GID used by frontend/backend container processes via gosu.
# Set to host group ID matching your target filesystem ownership.
PGID=1000
