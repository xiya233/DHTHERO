# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/dht_search
DATABASE_MAX_CONNECTIONS=20

# Feature toggles
FEATURE_SEARCH_ENABLED=true
FEATURE_LATEST_ENABLED=true
FEATURE_TRENDING_ENABLED=true
FEATURE_FILE_TREE_ENABLED=true
FEATURE_SEARCH_AUDIT_ENABLED=true
FEATURE_MEILI_ENABLED=false

# Search / audit
SEARCH_MAX_PAGE_SIZE=100
AUDIT_LOG_RETENTION_DAYS=180

# DHT crawler
CRAWLER_ENABLED=true
CRAWLER_PORT=6881
CRAWLER_NETMODE=ipv4
CRAWLER_METADATA_TIMEOUT=3
CRAWLER_MAX_METADATA_QUEUE_SIZE=100000
CRAWLER_MAX_METADATA_WORKER_COUNT=1000
CRAWLER_NODE_QUEUE_CAPACITY=100000
CRAWLER_HASH_QUEUE_CAPACITY=10000
# 0 means auto: clamp(2 * available_parallelism, 4, max(1, DATABASE_MAX_CONNECTIONS - 4))
CRAWLER_INGEST_WORKER_COUNT=0
CRAWLER_INGEST_QUEUE_CAPACITY=50000
CRAWLER_PROMETHEUS_ENABLED=true
CRAWLER_PROMETHEUS_LISTEN_ADDR=0.0.0.0:9000

# Meilisearch
MEILI_URL=http://127.0.0.1:7700
MEILI_API_KEY=
MEILI_INDEX=torrents
MEILI_BOOTSTRAP_ENABLED=true
MEILI_BOOTSTRAP_BATCH_SIZE=2000
MEILI_QUERY_TIMEOUT_MS=1200
MEILI_SYNC_BATCH_SIZE=256
MEILI_SYNC_FLUSH_INTERVAL_MS=250
MEILI_SYNC_QUEUE_CAPACITY=20000

# Admin dashboard
ADMIN_DASHBOARD_PASSWORD=
ADMIN_METRICS_SAMPLE_INTERVAL_SECS=5
ADMIN_METRICS_HISTORY_POINTS=720
