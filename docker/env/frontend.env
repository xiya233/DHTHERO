# ----------------------------------------
# Frontend (Next.js) runtime configuration
# ----------------------------------------

# Public backend base URL used by frontend server/BFF calls.
# In docker-compose use backend service name, not localhost.
NEXT_PUBLIC_API_BASE_URL=http://backend:8080

# Admin password used by frontend middleware and /api/admin/* BFF guard.
# MUST be exactly the same as backend ADMIN_DASHBOARD_PASSWORD.
ADMIN_DASHBOARD_PASSWORD=change_this_admin_password

# Enable site private mode middleware on frontend routes.
# true requires PRIVATE_SITE_PASSWORD and login flow.
PRIVATE_MODE_ENABLED=false

# Site private mode shared password.
# MUST be exactly the same as backend PRIVATE_SITE_PASSWORD when private mode is enabled.
PRIVATE_SITE_PASSWORD=
