# ----------------------------------------
# PostgreSQL container configuration
# ----------------------------------------

# DB superuser/app user created on first initialization.
# Use a dedicated non-default username in production.
POSTGRES_USER=dht

# Password for POSTGRES_USER.
# Change to a strong secret before production deployment.
POSTGRES_PASSWORD=change_this_pg_password

# Initial database name created on first initialization.
POSTGRES_DB=dhtsearch

# Data directory under mounted volume path.
# Keeping PGDATA nested avoids conflicts with root mount metadata files.
PGDATA=/var/lib/postgresql/data/pgdata
