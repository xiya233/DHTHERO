# ----------------------------------------
# Backend service runtime configuration
# ----------------------------------------

# Host/IP for Axum HTTP binding inside container.
# Keep 0.0.0.0 so Docker network and host port mapping can reach backend.
SERVER_HOST=0.0.0.0

# Backend HTTP port exposed by container.
# docker-compose maps this to host 8080 by default.
SERVER_PORT=8080

# Comma-separated allowed CORS origins for backend API.
# Set to your frontend domain(s) in production, e.g. https://app.example.com
# Leave empty to allow any origin (development only).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL connection DSN used by sqlx.
# IMPORTANT: use service name "postgres" (not localhost) in compose network.
DATABASE_URL=postgres://dht:change_this_pg_password@postgres:5432/dhtsearch

# Max DB pool connections.
# Higher value increases concurrency but also DB pressure; 20 is a balanced baseline.
DATABASE_MAX_CONNECTIONS=20

# Enable public /search endpoint.
# true = users can perform search; false = API returns FEATURE_DISABLED.
FEATURE_SEARCH_ENABLED=true

# Enable /latest endpoint and latest page data source.
FEATURE_LATEST_ENABLED=true

# Enable /trending endpoint and trending page data source.
FEATURE_TRENDING_ENABLED=true

# Enable /torrents/{hash}/files endpoint (file tree browsing).
FEATURE_FILE_TREE_ENABLED=true

# Enable search audit log writes into search_audit_logs partition table.
# true adds DB write per search request; turn off to reduce write load.
FEATURE_SEARCH_AUDIT_ENABLED=true

# Enable Meilisearch integration for /search relevance/latest sort path.
# true requires meilisearch service reachable via MEILI_URL.
FEATURE_MEILI_ENABLED=true

# Max allowed page size for list/search APIs (hard cap).
SEARCH_MAX_PAGE_SIZE=100

# Retention (days) for search audit logs cleanup task.
AUDIT_LOG_RETENTION_DAYS=180

# Enable/disable DHT crawler worker in backend process.
CRAWLER_ENABLED=true

# UDP listen port for DHT crawler node.
CRAWLER_PORT=6881

# DHT network mode (ipv4/ipv6).
CRAWLER_NETMODE=ipv4

# Metadata fetch timeout (seconds) per attempt.
CRAWLER_METADATA_TIMEOUT=3

# Upper bound of in-memory metadata queue length.
CRAWLER_MAX_METADATA_QUEUE_SIZE=100000

# Upper bound of metadata worker concurrency in dht-crawler.
CRAWLER_MAX_METADATA_WORKER_COUNT=1000

# Capacity for discovered node queue.
CRAWLER_NODE_QUEUE_CAPACITY=100000

# Capacity for discovered info_hash queue.
CRAWLER_HASH_QUEUE_CAPACITY=10000

# Ingest worker count for DB write pipeline.
# 0 = auto tune by CPU and DB pool size (recommended default).
CRAWLER_INGEST_WORKER_COUNT=0

# Queue capacity before ingest backpressure/drop policy starts.
CRAWLER_INGEST_QUEUE_CAPACITY=50000

# Enable Prometheus exporter for crawler metrics.
CRAWLER_PROMETHEUS_ENABLED=true

# Prometheus exporter bind address.
# Keep internal-only unless you explicitly publish this port.
CRAWLER_PROMETHEUS_LISTEN_ADDR=0.0.0.0:9000

# Meilisearch base URL.
# IMPORTANT: use service name "meilisearch" in compose network.
MEILI_URL=http://meilisearch:7700

# Meilisearch API key.
# Keep empty if Meili runs without master key; set when MEILI_MASTER_KEY is enabled.
MEILI_API_KEY=

# Meili index name used for torrent docs.
MEILI_INDEX=torrents

# Run full bootstrap indexing from PostgreSQL to Meili at backend startup.
# true helps cold-start consistency but costs startup IO.
MEILI_BOOTSTRAP_ENABLED=true

# Batch size for bootstrap fetch/upsert loop.
MEILI_BOOTSTRAP_BATCH_SIZE=2000

# Timeout for Meili query path in /search (milliseconds).
MEILI_QUERY_TIMEOUT_MS=1200

# Incremental sync batch size (ingest -> Meili).
MEILI_SYNC_BATCH_SIZE=256

# Incremental flush interval in milliseconds.
MEILI_SYNC_FLUSH_INTERVAL_MS=250

# Bounded queue capacity for incremental sync channel.
MEILI_SYNC_QUEUE_CAPACITY=20000

# Password for /api/v1/admin/* metrics/settings endpoints.
# MUST match frontend ADMIN_DASHBOARD_PASSWORD for admin panel BFF.
ADMIN_DASHBOARD_PASSWORD=change_this_admin_password

# Dashboard sampler interval (seconds) for in-memory chart points.
ADMIN_METRICS_SAMPLE_INTERVAL_SECS=5

# Max retained points in admin in-memory time-series ring buffer.
ADMIN_METRICS_HISTORY_POINTS=720

# Site-wide private mode switch.
# true + PRIVATE_SITE_PASSWORD set => all pages/APIs require login/password.
PRIVATE_MODE_ENABLED=false

# Shared password for private mode gate.
# MUST match frontend PRIVATE_SITE_PASSWORD when private mode is enabled.
PRIVATE_SITE_PASSWORD=
