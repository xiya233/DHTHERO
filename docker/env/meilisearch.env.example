# ----------------------------------------
# Meilisearch container configuration
# ----------------------------------------

# Runtime profile.
# Keep production for predictable performance defaults.
MEILI_ENV=production

# Disable telemetry to Meilisearch cloud.
MEILI_NO_ANALYTICS=true

# HTTP bind address inside container.
MEILI_HTTP_ADDR=0.0.0.0:7700

# Primary API key for Meilisearch.
# If set, backend MEILI_API_KEY must match this value.
# Leave empty only in trusted/private network environments.
MEILI_MASTER_KEY=

# Optional log verbosity (ERROR/WARN/INFO/DEBUG/TRACE).
MEILI_LOG_LEVEL=INFO
